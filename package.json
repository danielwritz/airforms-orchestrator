{
  "name": "@airforms/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic v1 orchestrator for Airforms turn handling",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "scan:secrets": "node scripts/scan-secrets.mjs"
  },
  "dependencies": {
    "@airforms/ui-schema": "file:../airforms-ui-schema",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}